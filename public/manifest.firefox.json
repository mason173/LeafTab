{
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "activeTab",
    "alarms",
    "identity",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "leaftab@cc",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": [
          "locationInfo",
          "authenticationInfo"
        ]
      }
    }
  }
}
