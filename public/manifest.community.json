{
  "manifest_version": 3,
  "name": "LeafTab",
  "version": "1.3.6",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "bootstrap.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "search",
    "permissions"
  ],
  "optional_permissions": [
    "bookmarks",
    "history",
    "tabs"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "host_permissions": [
    "https://www.leaftab.cc/*",
    "https://*/*",
    "http://*/*"
  ],
  "offline_enabled": true,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_appTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
