{
  "manifest_version": 3,
  "name": "LeafTab",
  "version": "1.3.10.1",
  "version_name": "1.4.0-alpha.1",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "bootstrap.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self'; child-src 'self';"
  },
  "sandbox": {
    "pages": [
      "ai-sandbox.html"
    ]
  },
  "permissions": [
    "search",
    "permissions"
  ],
  "optional_permissions": [
    "bookmarks",
    "history",
    "tabs"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "host_permissions": [
    "https://www.leaftab.cc/*",
    "https://api.iowen.cn/*",
    "https://icon.horse/*",
    "https://wttr.in/*",
    "https://cn.bing.com/*",
    "https://www.bing.com/*",
    "https://bing.biturl.top/*",
    "https://mason173.github.io/*",
    "https://raw.githubusercontent.com/*",
    "https://huggingface.co/*",
    "https://cas-bridge.xethub.hf.co/*",
    "https://cdn-lfs.hf.co/*",
    "https://cdn-lfs-us-1.hf.co/*",
    "https://cdn-lfs-eu-1.hf.co/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "https://ewebdav.pcloud.com/*",
    "https://webdav.pcloud.com/*",
    "https://webdav.mc.gmx.net/*",
    "https://webdav.icedrive.io/*",
    "https://webdav.yandex.com/*",
    "https://magentacloud.de/*",
    "https://dav.mailbox.org/*",
    "https://webdav.smartdrive.web.de/*"
  ],
  "offline_enabled": true,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_appTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
