{
  "manifest_version": 3,
  "name": "__MSG_appTitle__",
  "version": "2.0.5",
  "version_name": "2.0.5-alpha.7",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "bootstrap.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "permissions": [
    "search",
    "permissions",
    "activeTab",
    "bookmarks",
    "history",
    "scripting",
    "tabs",
    "identity"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "host_permissions": [
    "https://www.leaftab.cc/*",
    "https://api.iowen.cn/*",
    "https://icon.horse/*",
    "https://wttr.in/*",
    "https://cn.bing.com/*",
    "https://www.bing.com/*",
    "https://bing.biturl.top/*",
    "https://sug.so.360.cn/*",
    "https://mason173.github.io/*",
    "https://raw.githubusercontent.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://www.doubao.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://qwen.ai/*",
    "https://yuanbao.tencent.com/*",
    "https://copilot.microsoft.com/*",
    "https://dav.jianguoyun.com/*",
    "https://ewebdav.pcloud.com/*",
    "https://webdav.pcloud.com/*",
    "https://webdav.mc.gmx.net/*",
    "https://webdav.icedrive.io/*",
    "https://webdav.yandex.com/*",
    "https://magentacloud.de/*",
    "https://dav.mailbox.org/*",
    "https://webdav.smartdrive.web.de/*"
  ],
  "offline_enabled": true,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_appTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
