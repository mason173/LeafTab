{
  "manifest_version": 3,
  "name": "LeafTab",
  "version": "1.2.9",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "search",
    "permissions"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "host_permissions": [
    "https://www.leaftab.cc/*",
    "https://api.iowen.cn/*",
    "https://icon.horse/*",
    "https://ipapi.co/*",
    "https://api.bigdatacloud.net/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.open-meteo.com/*",
    "https://bing.biturl.top/*",
    "https://mason173.github.io/*",
    "https://raw.githubusercontent.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "https://ewebdav.pcloud.com/*",
    "https://webdav.pcloud.com/*",
    "https://webdav.mc.gmx.net/*",
    "https://webdav.icedrive.io/*",
    "https://webdav.yandex.com/*",
    "https://magentacloud.de/*",
    "https://dav.mailbox.org/*",
    "https://webdav.smartdrive.web.de/*"
  ],
  "offline_enabled": true,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_appTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
