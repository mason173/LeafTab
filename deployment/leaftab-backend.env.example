# LeafTab backend environment variables (example)
# Copy to: /etc/leaftab-backend.env
# Then: systemctl restart leaftab-backend

NODE_ENV=production
JWT_SECRET=change-this-in-production
SESSION_SECRET=change-this-in-production

# CORS allowlist (comma-separated)
CLIENT_URLS=https://example.com

# Behind reverse proxy (Caddy/Nginx)
TRUST_PROXY=1

# Session cookie for extension + cross-origin API requests
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true

# Admin export key for /admin/domains/export
ADMIN_API_KEY=change-this-admin-key
