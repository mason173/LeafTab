# LeafTab backend environment variables (example)
# Copy to: /etc/leaftab-backend.env
# Then: systemctl restart leaftab-backend

NODE_ENV=production
JWT_SECRET=change-this-in-production
SESSION_SECRET=change-this-in-production

# CORS allowlist (comma-separated)
CLIENT_URLS=https://example.com

# Behind reverse proxy (Caddy/Nginx)
TRUST_PROXY=1

# Session cookie for extension + cross-origin API requests
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true

# Rate limits
# Login/register
AUTH_LIMIT_WINDOW_MS=900000
AUTH_LIMIT_MAX=8

# General authenticated API
API_LIMIT_WINDOW_MS=900000
API_LIMIT_MAX=100

# Sync requests per account
SHORTCUTS_LIMIT_WINDOW_MS=60000
SHORTCUTS_LIMIT_MAX=100

# Sync requests per IP/network
SYNC_IP_LIMIT_WINDOW_MS=60000
SYNC_IP_LIMIT_MAX=90

# Captcha / release check
CAPTCHA_LIMIT_WINDOW_MS=900000
CAPTCHA_LIMIT_MAX=30
UPDATE_LIMIT_WINDOW_MS=60000
UPDATE_LIMIT_MAX=20

# Admin export key for /admin/domains/export
ADMIN_API_KEY=change-this-admin-key
