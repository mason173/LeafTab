      "devDependencies": {
            "@playwright/test": "^1.58.2",
            "@testing-library/jest-dom": "^6.9.1",
            "@testing-library/react": "^16.3.2",
            "@testing-library/user-event": "^14.6.1",
            "@types/chrome": "^0.1.37",
            "@types/node": "^20.10.0",
            "@types/react": "^19.2.10",
            "@types/react-dom": "^19.2.3",
            "@vitejs/plugin-react-swc": "^3.10.2",
            "jsdom": "^27.0.1",
            "vite": "6.3.5",
            "vitest": "^3.2.4"
      },
      "scripts": {
            "dev": "npm run icons:sync && vite --host",
            "build": "npm run build:community",
            "icons:sync": "node scripts/sync-local-icon-library.js",
            "icons:optimize:lossless": "npx --yes svgo@3 -f leaftab-icons-main/svgs --config=scripts/svgo-lossless.config.mjs",
            "icons:prepare:release": "npm run icons:optimize:lossless && npm run icons:sync",
            "test": "vitest run",
            "test:node": "vitest run -c vitest.node.config.ts",
            "test:e2e": "playwright test",
            "test:e2e:headed": "playwright test --headed",
            "test:plugin": "node scripts/run-plugin-checks.js",
            "test:watch": "vitest",
            "build:community": "node scripts/build-channel.js community",
            "build:store": "node scripts/build-channel.js store",
            "lint:firefox": "npx --yes web-ext lint -s build-firefox --output json",
            "verify:firefox:community": "npm run build:community && npm run lint:firefox",
            "verify:firefox:store": "npm run build:store && npm run lint:firefox",
            "pack:release": "node scripts/package-release-zips.js",
            "pack:release:community:no-icons": "npm run build:community && node scripts/package-release-zips.js community",
            "pack:release:store:no-icons": "npm run build:store && node scripts/package-release-zips.js store",
            "pack:release:community": "npm run icons:prepare:release && npm run pack:release:community:no-icons",
            "pack:release:store": "npm run icons:prepare:release && npm run pack:release:store:no-icons",
            "pack:release:all": "npm run icons:prepare:release && npm run pack:release:community:no-icons && npm run pack:release:store:no-icons",
            "verify:release:community": "node scripts/verify-release-channel.js community",
            "verify:release:store": "node scripts/verify-release-channel.js store",
            "publish:github": "node scripts/publish-github-release.js",
            "check:publish-safe": "bash scripts/guard_github_publish.sh"
      },
      "license": "GPL-3.0-or-later"
}
